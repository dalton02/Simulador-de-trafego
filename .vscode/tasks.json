{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All C++ Files",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                " g++ -std=c++20  $(find . -type f -name '*.cpp') -o programa"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}