{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Projeto Simulador",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++20",
        "-g",
        "src/main.cpp",
        "src/concurrency/synchronization.cpp",
        "src/concurrency/traffic_light.cpp",
        "src/core/Grid.cpp",
        "src/interface/interface.cpp",
        "src/utils/utils.cpp",
        "src/vehicles/car.cpp",
        "-o",
        "simulador.exe",
        "-pthread",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system"
      ],
      "options": {
        "shell": {
          "executable": "C:\\msys64\\usr\\bin\\bash.exe",
          "args": ["-c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
