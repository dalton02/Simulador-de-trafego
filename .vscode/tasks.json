{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All C++ Files",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "g++ -std=c++17 -g $(find ${workspaceFolder} -name \"*.cpp\") -o ${workspaceFolder}/main  && ${workspaceFolder}/main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}